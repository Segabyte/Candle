# Normalize line endings: store text as LF in the repo, check out native.
# Silences the "LF will be replaced by CRLF" warnings on Windows.
* text=auto

# Scripts that must keep a specific ending regardless of platform
*.sh   text eol=lf
*.bash text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Explicitly text (in case auto-detection is ever unsure)
*.ts   text
*.tsx  text
*.js   text
*.jsx  text
*.json text
*.md   text
*.html text
*.css  text
*.svg  text
*.yml  text
*.yaml text

# Binary files — never convert or diff as text
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.exe  binary
*.dll  binary
*.node binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.7z   binary
